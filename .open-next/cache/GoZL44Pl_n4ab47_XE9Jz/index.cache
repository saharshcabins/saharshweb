    duration-300\n          ease-in-out\n          flex\n          items-center\n          ml-0\n          group-hover:w-6 group-hover:opacity-100 group-hover:ml-3\n        \"><div class=\"w-6 h-6 text-[var(--text-light)]\"><svg viewBox=\"0 0 28 26\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" class=\"transform scale-x-[-1] \"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M0.73645 11.9334L0.762199 11.9356V11.9313H0.868309C6.38999 11.4816 10.7393 6.64917 10.7393 0.752352L10.7363 0.5H12.7616L12.7646 0.752352C12.7646 5.43486 10.4581 9.55228 6.971 11.9313L27.2646 11.9356V14.0622L6.95452 14.0579C10.4519 16.4348 12.7646 20.5576 12.7646 25.2476L12.7616 25.5H10.7363L10.7393 25.2476C10.7393 19.3239 6.35084 14.4742 0.792076 14.0622L0.735416 14.0666V14.0579V11.9431V11.9345L0.73645 11.9334Z\" fill=\"currentColor\"></path></svg></div></span></button></div></div></div><div class=\"flex flex-col gap-20\"><div class=\"w-[90%] mx-auto py-20\"><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><div class=\"w-full flex flex-col items-center gap-14 md:py-20 px-4\"><div class=\"flex flex-col items-center gap-3 text-center md:hidden\"><span class=\"inline-block text-center leading-snug \"><span class=\"text-base font-bold text-[var(--text-dark)] leading-[1.2]\" style=\"font-size:30px\">The </span><span class=\"text-base font-bold text-[var(--color-primary)] leading-[1.2]\" style=\"font-size:30px\">Saharsh </span><span class=\"text-base font-bold text-[var(--text-dark)] leading-[1.2]\" style=\"font-size:30px\">Advantage</span></span><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Why wait months when you can be ready in weeks?<!-- --> </span></div><div class=\"flex flex-col items-center gap-3 text-center max-md:hidden\"><span class=\"inline-block text-center leading-snug \"><span class=\"text-base font-bold text-[var(--text-dark)] leading-[1.2]\" style=\"font-size:clamp(60px, 5.208vw, 75px)\">The </span><span class=\"text-base font-bold text-[var(--color-primary)] leading-[1.2]\" style=\"font-size:clamp(60px, 5.208vw, 75px)\">Saharsh </span><span class=\"text-base font-bold text-[var(--text-dark)] leading-[1.2]\" style=\"font-size:clamp(60px, 5.208vw, 75px)\">Advantage</span></span><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:clamp(16px, 1.389vw, 20px)\">Why wait months when you can be ready in weeks?<!-- --> </span></div><div style=\"width:100%;max-width:1000px;display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:16px;align-items:start\"><div style=\"border-radius:16px;overflow:hidden;background:var(--color-primary)\"><div style=\"padding:24px 24px 0\" class=\"flex flex-col\"><span class=\"w-fit\" style=\"display:inline-block;font-size:11px;font-weight:500;padding:3px 10px;border-radius:999px;background:rgba(255,255,255,0.2);color:#fff;margin-bottom:12px\">✦ Recommended</span><span class=\"text-base font-bold text-[var(--text-light)]\" style=\"font-size:clamp(26px, 2.222vw, 32px)\">Saharsh Cabins</span><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:clamp(13px, 1.111vw, 16px)\">Stop wasting time. Start building smarter.<!-- --> </span></div><div style=\"height:0.5px;margin:16px 24px 0;background:rgba(255,255,255,0.25)\"></div><ul style=\"padding:0 24px 24px;margin:0;list-style:none\"><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid rgba(255,255,255,0.15)\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Get operational 30–60% faster — no waiting, no delays\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid rgba(255,255,255,0.15)\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Lock your budget upfront — no hidden costs, ever</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid rgba(255,255,255,0.15)\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Factory-built precision — zero compromise on quality\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid rgba(255,255,255,0.15)\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Install in weeks, not months — minimal site chaos\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid rgba(255,255,255,0.15)\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Cut waste by up to 90% — smarter, cleaner construction\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid rgba(255,255,255,0.15)\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Built for Site conditions — durable, reliable, proven\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid rgba(255,255,255,0.15)\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Scale instantly when you grow — no rework, no hassle\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:none\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(255,255,255,0.2)\"></circle><path d=\"M5 9.5L7.5 12L13 6.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-light)]\" style=\"font-size:14px\">Premium finish, every single time — consistency you can trust\t</span></li></ul></div><div style=\"border-radius:16px;overflow:hidden;background:#fff;border:0.5px solid var(--color-border, #e5e7eb)\"><div style=\"padding:24px 24px 0\" class=\"flex flex-col\"><span class=\"w-fit\" style=\"display:inline-block;font-size:11px;font-weight:500;padding:3px 10px;border-radius:999px;background:#f3f4f6;color:#6b7280;margin-bottom:12px\">Traditional</span><span class=\"text-base font-bold text-[var(--text-dark)]\" style=\"font-size:clamp(26px, 2.222vw, 32px)\">Traditional Construction</span><span class=\"text-base font-normal text-[var(--text-muted)]\" style=\"font-size:clamp(13px, 1.111vw, 16px)\">Slow. Unpredictable. Expensive.<!-- --> </span></div><div style=\"height:0.5px;margin:16px 24px 0;background:#e5e7eb\"></div><ul style=\"padding:0 24px 24px;margin:0;list-style:none\"><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid #e5e7eb\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Stuck for 12–24+ months before you even start operating\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid #e5e7eb\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Budgets spiral out of control — surprises at every stage</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid #e5e7eb\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Quality depends on labor &amp; site conditions — no consistency\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid #e5e7eb\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Endless noise, dust &amp; disruption — impacts your business\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid #e5e7eb\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Massive material wastage — inefficient and costly\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid #e5e7eb\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Weather delays your progress — timelines keep slipping\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:0.5px solid #e5e7eb\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Hard to expand or modify later — you’re locked in\t</span></li><li class=\"items-center\" style=\"display:flex;gap:10px;padding:12px 0;min-height:48px;border-bottom:none\"><svg style=\"flex-shrink:0;margin-top:2px\" width=\"16\" height=\"16\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"9\" fill=\"rgba(239,68,68,0.1)\"></circle><path d=\"M6 6l6 6M12 6l-6 6\" stroke=\"#ef4444\" stroke-width=\"1.8\" stroke-linecap=\"round\"></path></svg><span class=\"text-base font-normal text-[var(--text-dark)]\" style=\"font-size:14px\">Final output? Uncertain. — you pay more, risk more\t</span></li></ul></div></div></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$-->        <div class=\"w-full flex flex-col items-center gap-12 py-16 px-4\"><span class=\"inline-block text-center leading-snug md:hidden\"><span class=\"text-base font-bold text-[var(--text-dark)] leading-[1.2]\" style=\"font-size:30px\">Frequently Asked </span><span class=\"text-base font-bold text-[var(--color-primary)] leading-[1.2]\" style=\"font-size:30px\">Questions</span></span><span class=\"inline-block text-center leading-snug max-md:hidden\"><span class=\"text-base font-bold text-[var(--text-dark)] leading-[1.2]\" style=\"font-size:clamp(60px, 5.208vw, 75px)\">Frequently Asked </span><span class=\"text-base font-bold text-[var(--color-primary)] leading-[1.2]\" style=\"font-size:clamp(60px, 5.208vw, 75px)\">Questions</span></span><div class=\"w-full max-w-[900px] space-y-4\"><div class=\"bg-white rounded-xl  overflow-hidden border border-gray-200\"><button class=\"w-full flex items-center justify-between p-4 sm:p-6 text-left hover:bg-gray-50 transition-colors\"><span class=\"text-lg font-semibold text-[var(--text-dark)] pr-4 text-[14px] sm:text-[18px] md:text-[20px]\">What is the difference between modular construction and traditional RCC construction?</span><div class=\"flex-shrink-0 w-6 h-6 flex items-center justify-center transition-transform duration-300 \"><span class=\"text-base font-light text-[var(--color-primary)] text-[18px] sm:text-[20px]\">+</span></div></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-6 pt-2 border-t border-gray-100\"><span class=\"text-base font-normal text-[var(--text-muted)] leading-relaxed text-[13px] sm:text-[15px] md:text-[20px]\">Modular construction is built off-site in a controlled factory setting, making it significantly faster, more eco-friendly, and portable compared to traditional, labor-intensive RCC buildings.</span></div></div></div><div class=\"bg-white rounded-xl  overflow-hidden border border-gray-200\"><button class=\"w-full flex items-center justify-between p-4 sm:p-6 text-left hover:bg-gray-50 transition-colors\"><span class=\"text-lg font-semibold text-[var(--text-dark)] pr-4 text-[14px] sm:text-[18px] md:text-[20px]\">What materials are used in manufacturing the cabins and homes?</span><div class=\"flex-shrink-0 w-6 h-6 flex items-center justify-center transition-transform duration-300 \"><span class=\"text-base font-light text-[var(--color-primary)] text-[18px] sm:text-[20px]\">+</span></div></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-6 pt-2 border-t border-gray-100\"><span class=\"text-base font-normal text-[var(--text-muted)] leading-relaxed text-[13px] sm:text-[15px] md:text-[20px]\">Drawing on our 15 years of expertise, we use high-grade galvanized steel frames paired with spray foam insulation and SPC wall panels for maximum durability and premium finish.</span></div></div></div><div class=\"bg-white rounded-xl  overflow-hidden border border-gray-200\"><button class=\"w-full flex items-center justify-between p-4 sm:p-6 text-left hover:bg-gray-50 transition-colors\"><span class=\"text-lg font-semibold text-[var(--text-dark)] pr-4 text-[14px] sm:text-[18px] md:text-[20px]\">What are the construction and manufacturing timelines before shipping?</span><div class=\"flex-shrink-0 w-6 h-6 flex items-center justify-center transition-transform duration-300 \"><span class=\"text-base font-light text-[var(--color-primary)] text-[18px] sm:text-[20px]\">+</span></div></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-6 pt-2 border-t border-gray-100\"><span class=\"text-base font-normal text-[var(--text-muted)] leading-relaxed text-[13px] sm:text-[15px] md:text-[20px]\">Turn-key project delivery typically takes just 10 - 12 weeks, and with our four facilities across India, we ensure rapid domestic delivery and efficient shipping for international exports.</span></div></div></div><div class=\"bg-white rounded-xl  overflow-hidden border border-gray-200\"><button class=\"w-full flex items-center justify-between p-4 sm:p-6 text-left hover:bg-gray-50 transition-colors\"><span class=\"text-lg font-semibold text-[var(--text-dark)] pr-4 text-[14px] sm:text-[18px] md:text-[20px]\">Are these structures customizable?</span><div class=\"flex-shrink-0 w-6 h-6 flex items-center justify-center transition-transform duration-300 \"><span class=\"text-base font-light text-[var(--color-primary)] text-[18px] sm:text-[20px]\">+</span></div></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-6 pt-2 border-t border-gray-100\"><span class=\"text-base font-normal text-[var(--text-muted)] leading-relaxed text-[13px] sm:text-[15px] md:text-[20px]\">Yes, these structures are customizable! You can fully customize floor plans, exterior cladding, interior finishes, and layouts to perfectly match the specific needs of your home, resort, or commercial space.</span></div></div></div></div></div></div></div></div><div class=\"block lg:hidden\"><div class=\"flex flex-col items-center w-full min-h-screen bg-[var(--color-background)]\"><div class=\"flex flex-col items-center gap-20 w-full  mx-auto \"><div class=\"w-full h-[90vh] md:h-[90vh] relative flex flex-col justify-between overflow-hidden\"><div class=\"absolute inset-0 w-full h-full z-0\" style=\"opacity:0\"><img alt=\"Cottages background\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover object-center\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image/?url=%2Fassets%2Fbuilt%2Fcottage_mobile.png&amp;w=640&amp;q=75 640w, /_next/image/?url=%2Fassets%2Fbuilt%2Fcottage_mobile.png&amp;w=750&amp;q=75 750w, /_next/image/?url=%2Fassets%2Fbuilt%2Fcottage_mobile.png&amp;w=828&amp;q=75 828w, /_next/image/?url=%2Fassets%2Fbuilt%2Fcottage_mobile.png&amp;w=1080&amp;q=75